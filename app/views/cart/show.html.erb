<div class="container mt-4">
  <h2>🛒 Shopping Cart</h2>
  <% if @cart_items.empty? %>
    <div class="alert alert-info mt-3">
      Your cart is empty. <%= link_to "Continue Shopping", products_path %>
    </div>
  <% else %>
    <table class="table table-bordered mt-3">
      <thead class="table-dark">
        <tr>
          <th>Product</th>
          <th>Price</th>
          <th>Quantity</th>
          <th>Total</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <% @cart_items.each do |item| %>
          <tr>
            <td><%= item[:product].name %></td>
            <td>$<%= item[:price] %></td>
            <td>
              <%= form_with url: cart_update_path(item[:product].id), method: :post, local: true do |f| %>
                <div class="d-flex">
                  <%= f.number_field :quantity, value: item[:quantity], min: 1, class: "form-control w-50" %>
                  <%= f.submit "Update", class: "btn btn-sm btn-secondary ms-2" %>
                </div>
              <% end %>
            </td>
            <td>$<%= item[:line_total].round(2) %></td>
            <td>
              <%= button_to "Remove", cart_remove_path(item[:product].id), method: :delete, class: "btn btn-danger btn-sm" %>
            </td>
          </tr>
        <% end %>
      </tbody>
      <tfoot>
        <tr>
          <td colspan="3" class="text-end fw-bold">Subtotal:</td>
          <td colspan="2" class="fw-bold">$<%= @total.round(2) %></td>
        </tr>
      </tfoot>
    </table>
    <div class="d-flex justify-content-between mt-3">
      <%= link_to "← Continue Shopping", products_path, class: "btn btn-outline-secondary" %>
      <%= link_to "Proceed to Checkout →", new_payment_path, class: "btn btn-success btn-lg" %>
  <% end %>
</div>
