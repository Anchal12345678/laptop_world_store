<div class="container mt-4">
  <h2 class="mb-4">Shop by Category</h2>
  <div class="row">
    <% @categories.each do |category| %>
      <div class="col-md-6 mb-4">
        <div class="card h-100 shadow-sm border-0">
          <div class="card-body text-center p-5">
            <% if category.name == "Gaming Laptops" %>
              <div class="display-1 mb-3">🎮</div>
            <% elsif category.name == "Business Laptops" %>
              <div class="display-1 mb-3">💼</div>
            <% elsif category.name == "Student Laptops" %>
              <div class="display-1 mb-3">🎓</div>
            <% else %>
              <div class="display-1 mb-3">✨</div>
            <% end %>
            <h3><%= category.name %></h3>
            <p class="text-muted"><%= category.description %></p>
            <p><strong><%= category.products.count %></strong> products</p>
            <%= link_to "Shop Now", category_path(category), class: "btn btn-primary btn-lg" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
