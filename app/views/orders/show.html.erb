<div class="container mt-4">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><%= link_to "Home", root_path %></li>
      <li class="breadcrumb-item"><%= link_to "My Orders", orders_path %></li>
      <li class="breadcrumb-item active">Order #<%= @order.id %></li>
    </ol>
  </nav>
  <h2>Order #<%= @order.id %></h2>
  <p class="text-muted">Placed on <%= @order.created_at.strftime("%B %d, %Y") %></p>
  <span class="badge bg-<%= @order.status == 'pending' ? 'warning' : 'success' %> mb-3">
    Status: <%= @order.status.capitalize %>
  </span>
  <table class="table table-bordered mt-3">
    <thead class="table-dark">
      <tr><th>Product</th><th>Quantity</th><th>Unit Price</th><th>Total</th></tr>
    </thead>
    <tbody>
      <% @order.order_items.each do |item| %>
        <tr>
          <td><%= item.product.name %></td>
          <td><%= item.quantity %></td>
          <td>$<%= item.unit_price %></td>
          <td>$<%= item.line_total.round(2) %></td>
        </tr>
      <% end %>
    </tbody>
    <tfoot>
      <tr><td colspan="3" class="text-end">Subtotal:</td><td>$<%= @order.subtotal.round(2) %></td></tr>
      <tr><td colspan="3" class="text-end">Tax:</td><td>$<%= @order.tax.round(2) %></td></tr>
      <tr class="fw-bold"><td colspan="3" class="text-end">Total:</td><td>$<%= @order.total.round(2) %></td></tr>
    </tfoot>
  </table>
  <div class="mt-3">
    <%= link_to "← Back to Orders", orders_path, class: "btn btn-secondary" %>
    <%= link_to "Continue Shopping", products_path, class: "btn btn-primary" %>
  </div>
</div>
