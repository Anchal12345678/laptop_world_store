<% content_for :breadcrumbs do %>
  <li class="breadcrumb-item"><%= link_to "Home", root_path %></li>
  <li class="breadcrumb-item"><%= link_to "All Products", products_path %></li>
  <li class="breadcrumb-item"><%= link_to @product.category.name, category_path(@product.category) %></li>
  <li class="breadcrumb-item active"><%= @product.name %></li>
<% end %>

<div class="container mt-4">
  <div class="row">
    <div class="col-md-6">
      <% if @product.image.attached? %>
        <%= image_tag @product.image.variant(:large),
            class: "img-fluid rounded" %>
      <% else %>
        <div class="bg-light text-center py-5 rounded">
          <span class="fs-1">💻</span>
        </div>
      <% end %>
    </div>
    <div class="col-md-6">
      <h1><%= @product.name %></h1>
      <p class="text-muted">Category:
        <span class="badge bg-primary"><%= @product.category.name %></span>
      </p>

      <% if @product.tags.any? %>
        <div class="mb-3">
          <% @product.tags.each do |tag| %>
            <span class="badge bg-secondary me-1"><%= tag.name %></span>
          <% end %>
        </div>
      <% end %>

      <% if @product.on_sale && @product.sale_price %>
        <h3 class="text-danger">
          $<%= @product.sale_price %>
          <span class="badge bg-danger ms-2">ON SALE</span>
        </h3>
        <p class="text-muted text-decoration-line-through">
          Was: $<%= @product.current_price %>
        </p>
      <% else %>
        <h3>$<%= @product.current_price %></h3>
      <% end %>

      <hr>
      <p><%= @product.description %></p>
      <p class="text-muted">
        <strong>In Stock:</strong> <%= @product.stock_quantity %> units
      </p>

      <% if @product.stock_quantity > 0 %>
        <%= button_to "🛒 Add to Cart", cart_add_path(@product),
            method: :post, class: "btn btn-success btn-lg w-100 mt-3" %>
      <% else %>
        <button class="btn btn-secondary btn-lg w-100 mt-3" disabled>
          Out of Stock
        </button>
      <% end %>

      <%= link_to "← Back to Products", products_path,
          class: "btn btn-outline-secondary w-100 mt-2" %>
    </div>
  </div>
</div>