<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
  <div class="container">
    <%= link_to "💻 Laptop World Store", root_path, class: "navbar-brand fw-bold" %>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNav">
      <ul class="navbar-nav me-auto">
        <li class="nav-item"><%= link_to "All Products", products_path, class: "nav-link" %></li>
        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Categories</a>
          <ul class="dropdown-menu">
            <li><%= link_to "All Categories", categories_path, class: "dropdown-item" %></li>
            <li><hr class="dropdown-divider"></li>
            <% Category.all.each do |category| %>
              <li><%= link_to category.name, category_path(category), class: "dropdown-item" %></li>
            <% end %>
          </ul>
        </li>
      </ul>
      <ul class="navbar-nav">
        <li class="nav-item">
          <%= link_to cart_path, class: "nav-link" do %>
            🛒 Cart
            <% cart_count = session[:cart]&.values&.sum || 0 %>
            <% if cart_count > 0 %>
              <span class="badge bg-danger"><%= cart_count %></span>
            <% end %>
          <% end %>
        </li>
        <% if admin_user_signed_in? %>
          <li class="nav-item">
            <%= link_to "⚙️ Admin Dashboard", admin_root_path, class: "nav-link btn btn-warning text-dark px-3 ms-2 rounded" %>
          </li>
          <li class="nav-item">
            <%= button_to "Logout", destroy_admin_user_session_path, method: :delete, class: "nav-link btn btn-link text-white" %>
          </li>
        <% elsif user_signed_in? %>
          <li class="nav-item"><%= link_to "📦 My Orders", orders_path, class: "nav-link" %></li>
          <li class="nav-item"><%= link_to current_user.email, "#", class: "nav-link" %></li>
          <li class="nav-item">
            <%= button_to "Logout", destroy_user_session_path, method: :delete, class: "nav-link btn btn-link text-white" %>
          </li>
        <% else %>
          <li class="nav-item"><%= link_to "Login", new_user_session_path, class: "nav-link" %></li>
          <li class="nav-item"><%= link_to "Sign Up", new_user_registration_path, class: "nav-link" %></li>
        <% end %>
      </ul>
    </div>
  </div>
</nav>
